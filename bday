<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Happy Birthday 🎉</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
    margin: 0;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: radial-gradient(circle, #1a1a2e, #0f0f1a);
    color: white;
    font-family: Arial, sans-serif;
    overflow: hidden;
    text-align: center;
}

.container {
    z-index: 2;
}

h1 {
    font-size: 3em;
    animation: glow 2s infinite alternate;
}

@keyframes glow {
    from { text-shadow: 0 0 10px #ff4d6d; }
    to { text-shadow: 0 0 30px #ff4d6d; }
}

button {
    padding: 12px 24px;
    font-size: 18px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    background: #ff4d6d;
    color: white;
    margin-top: 20px;
}

button:hover {
    background: #ff2e55;
}

</style>
</head>

<body>

<div class="container">
    <h1>🎂 Happy Birthday! 🎉</h1>
    <p>Click to start your surprise</p>
    <button onclick="start()">Start Celebration</button>
</div>

<!-- MUSIC -->
<audio id="music" loop>
    <source src="https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/happy-birthday.mp3" type="audio/mpeg">
</audio>

<!-- CONFETTI LIBRARY -->
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

<script>
function start() {
    // MUSIC (works because user interacted)
    const music = document.getElementById("music");
    music.play();

    // BIG CONFETTI BURST
    const duration = 3000;
    const end = Date.now() + duration;

    (function frame() {
        confetti({
            particleCount: 6,
            spread: 120,
            origin: { y: 0.6 }
        });

        if (Date.now() < end) {
            requestAnimationFrame(frame);
        }
    })();

    // UI change
    document.querySelector(".container").innerHTML = `
        <h1>🎉 Let the chaos begin 🎉</h1>
        <p>Happy Birthday — no refunds, no regrets.</p>
    `;
}
</script>

</body>
</html>
